<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color: dull white -->
    <solid android:color="#F5F5F5"/> <!-- Light grayish white -->

    <!-- Border (optional, makes it look boxed) -->
    <stroke
        android:width="2dp"
        android:color="#CCCCCC"/> <!-- Soft gray border -->

    <!-- Vertical rectangle: taller than wide -->
    <size
        android:width="120dp"
        android:height="200dp"/>

    <!-- Slightly rounded corners -->
    <corners android:radius="8dp"/>
</shape>