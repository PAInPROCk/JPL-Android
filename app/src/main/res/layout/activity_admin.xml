<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="15dp"
    android:background="#9EFFB6"
    tools:context=".activities.AdminActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/admin"
        android:layout_centerHorizontal="true"
        android:textStyle="bold"
        android:textSize="20dp"
        android:layout_marginTop="10dp"
        android:id="@+id/admin"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:layout_below="@id/admin"
        android:id="@+id/admin_auc_set">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/admin_set"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DEFFF6"
            android:padding="5dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Random Mode"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textSize="20sp"/>
        </LinearLayout>
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#66BB6A"
                android:text="Start Auction"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"/>
            <Button
                android:id="@+id/btnPlayerReg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#8D78FF"
                android:text="New Player Registration"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"/>
            <Button
                android:id="@+id/btnTeamReg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#8D78FF"
                android:text="New Team Registration"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:layout_marginTop="7dp"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/admin_auc_set"
        android:padding="24dp"
        android:layout_marginTop="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batch Player Upload"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="10dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#F4FFFD"
                android:gravity="center_vertical">
                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/btnChooseFile"
                    android:text="Choose File"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#DDDDDD"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvFileName"
                    android:layout_weight="1"
                    android:paddingStart="12dp"
                    android:padding="10dp"
                    android:text="No file chosen"
                    android:textColor="#888888"/>

            </LinearLayout>
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnSubmitBatch"
                android:layout_marginTop="16dp"
                android:backgroundTint="#FFD54F"
                android:text="Submit Batch Upload"
                android:textColor="#5D4037"
                android:textAllCaps="false"/>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</RelativeLayout>