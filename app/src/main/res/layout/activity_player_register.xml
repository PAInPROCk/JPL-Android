<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg"
    tools:context=".activities.PlayerRegisterActivity">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:padding="12dp">

        <!-- IMAGE SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <ImageView
                android:id="@+id/playerImage"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/player"
                android:scaleType="centerCrop"
                android:background="@drawable/image_border" />

            <Button
                android:id="@+id/btnUploadImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Image"
                android:layout_marginTop="8dp"
                android:backgroundTint="#E6DD25" />
        </LinearLayout>

        <!-- FULL WIDTH -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Player Name"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etplayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/black"
                android:hint="Enter player name"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- FULL WIDTH -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Father Name"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etfatherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter father name"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- LEFT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Surname"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etsurName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Surname"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- RIGHT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NickName"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etnickName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nickname"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- EMAIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- AGE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Age"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textColor="@color/black"
                android:hint="Age"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- MOBILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etmobile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:gravity="center"
                android:textColor="@color/black"
                android:hint="Mobile"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- GENDER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Gender"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#4CAF50"
                android:padding="6dp" />

            <Spinner
                android:id="@+id/etgenderspinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ROLE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#F44336"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etrole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Role"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- CATEGORY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#F44336"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etcategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Category"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- STYLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Style"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#F44336"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Playing Style"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- BASE PRICE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            android:background="#D9E2FA"
            android:padding="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Base Price"
                android:textColor="#fff"
                android:gravity="center"
                android:background="#F44336"
                android:padding="6dp" />

            <EditText
                android:id="@+id/etBasePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textColor="@color/black"
                android:hint="Base Price"
                android:background="@drawable/input_box" />
        </LinearLayout>

        <!-- SUBMIT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:gravity="center"
            android:padding="8dp">

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Submit"
                android:backgroundTint="#2FA0E6" />
        </LinearLayout>

    </GridLayout>

</ScrollView>