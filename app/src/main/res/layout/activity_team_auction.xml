<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/playerCard"
            android:layout_marginTop="25dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">
                <!-- Player Image  -->
                <ImageView
                    android:id="@+id/playerImage"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/player"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_border"/>

                <!-- Player Info -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:background="@drawable/text_border_green"
                            android:text="Player Name"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/pName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/text_border_grey"
                            android:textColor="@color/black"
                            android:textColorHint="@color/black"
                            android:hint="Name"
                            android:padding="5dp"
                            android:layout_marginStart="3dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:padding="5dp"
                            android:textStyle="bold"
                            android:textColor="#fff"
                            android:textSize="12sp"
                            android:background="@drawable/text_border_red"
                            android:text="Category: "/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:hint="A"
                            android:textColorHint="@color/black"
                            android:id="@+id/pCategory"
                            android:background="@drawable/text_border_grey"
                            android:textColor="@color/black"
                            android:padding="5dp"
                            android:layout_marginStart="3dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_marginTop="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:background="@drawable/text_border_red"
                            android:text="Style: "
                            android:textSize="12sp"
                            android:textColor="#fff"/>
                        <TextView
                            android:id="@+id/pStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:hint="Right Hand"
                            android:textColorHint="@color/black"
                            android:background="@drawable/text_border_grey"
                            android:textColor="@color/black"
                            android:padding="5dp"
                            android:layout_marginStart="3dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/playerPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/playerCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/priceSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp">

                <!-- Base Price -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/container_border_bp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/basePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Base Price"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:padding="12dp" />
                    <TextView
                        android:id="@+id/playerBasePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="₹5000"
                        android:textColor="@color/black"
                        android:padding="12dp"
                        android:layout_gravity="center"/>
                </LinearLayout>



                <!-- Current Price -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/container_border_cp"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/currentPrice"
                        android:text="Current Price"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:padding="10dp"/>
                    <TextView
                        android:id="@+id/playerCurrentPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹5000"
                        android:textColor="@color/black"
                        android:layout_gravity="center"
                        android:padding="12dp"/>
                </LinearLayout>


            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/timer_teaminfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/playerPrice"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- TIMER CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_margin="15dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/timerText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="02:00"
                    android:layout_marginTop="10dp"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/timer_bg"/>
            </androidx.cardview.widget.CardView>


            <!-- TEAM INFO CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                android:layout_marginStart="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <!-- Team Logo -->
                    <ImageView
                        android:id="@+id/teamLogo"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/player"
                        android:layout_marginBottom="6dp"/>

<!--                    &lt;!&ndash; Current Bid &ndash;&gt;-->
<!--                    <TextView-->
<!--                        android:id="@+id/teamBidPrice"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="₹10500"-->
<!--                        android:textColor="#F44336"-->
<!--                        android:textStyle="bold"-->
<!--                        android:textSize="16sp"/>-->

                    <!-- Purse -->
                    <TextView
                        android:id="@+id/teamPurse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹759500"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/teamBid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:padding="10dp"
            app:layout_constraintTop_toBottomOf="@id/timer_teaminfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:gravity="center"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/bidButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:backgroundTint="#4CAF50"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/teamBid"
            android:id="@+id/notificationRecycler"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>